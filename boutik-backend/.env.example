# BoutiK Backend - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# Base de données PostgreSQL
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://boutik_user:motdepasse@localhost:5432/boutik_db"

# JWT Secret - changer en production (minimum 32 caractères)
JWT_SECRET="boutik-secret-key-changer-en-production-2024"
JWT_EXPIRES_IN="30d"

# Serveur
PORT=3001
NODE_ENV="development"

# Frontend URL (pour CORS)
FRONTEND_URL="http://localhost:5173"

# En production sur Render :
# FRONTEND_URL="https://boutik.vercel.app"
