// BoutiK - Schéma Prisma (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── BOUTIQUE ────────────────────────────────────────────────────────────────
model Boutique {
  id        String   @id @default(uuid())
  nom       String
  whatsapp  String   @unique
  password  String
  adresse   String?
  logo      String?
  siteWeb   String?
  bloquee   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories Categorie[]
  produits   Produit[]
  ventes     Vente[]
  vendeurs   Vendeur[]

  @@map("boutiques")
}

// ─── VENDEUR ─────────────────────────────────────────────────────────────────
model Vendeur {
  id         String    @id @default(uuid())
  nom        String
  boutiqueId String
  boutique   Boutique  @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  ventes     Vente[]

  @@map("vendeurs")
}

// ─── CATEGORIE ───────────────────────────────────────────────────────────────
model Categorie {
  id         String    @id
  boutiqueId String
  boutique   Boutique  @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  nom        String
  prefix     String
  prixAchat  Int
  prixVente  Int
  quantite   Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  produits Produit[]
  ventes   Vente[]

  @@map("categories")
}

// ─── PRODUIT ─────────────────────────────────────────────────────────────────
model Produit {
  id          String    @id
  boutiqueId  String
  boutique    Boutique  @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  categorieId String
  categorie   Categorie @relation(fields: [categorieId], references: [id], onDelete: Cascade)
  nom         String
  prixAchat   Int
  prixVente   Int
  vendu       Boolean   @default(false)
  dateVente   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  vente Vente?

  @@map("produits")
}

// ─── VENTE ───────────────────────────────────────────────────────────────────
model Vente {
  id          String    @id
  boutiqueId  String
  boutique    Boutique  @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  produitId   String    @unique
  produit     Produit   @relation(fields: [produitId], references: [id])
  categorieId String
  categorie   Categorie @relation(fields: [categorieId], references: [id])
  vendeurId   String?
  vendeur     Vendeur?  @relation(fields: [vendeurId], references: [id])
  nomProduit  String
  prixVente   Int
  prixAchat   Int
  benefice    Int
  vendeurNom  String    @default("Gérant")
  date        DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@map("ventes")
}
